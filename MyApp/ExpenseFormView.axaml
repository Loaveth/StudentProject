<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyApp.ExpenseFormView">

    <ScrollViewer>
        <StackPanel Margin="30,24" Spacing="16" MaxWidth="480">

            <TextBlock Text="Add Expense" FontSize="22" FontWeight="Bold"/>

            <!-- Expense entry -->
            <Border Background="#f0f0fa" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="New Expense" FontWeight="SemiBold"/>

                    <TextBox Name="ExpenseNameInput" Watermark="Expense name (e.g. Rent)"/>
                    <TextBox Name="ExpenseAmountInput" Watermark="Amount (e.g. 850)"/>

                    <TextBlock Text="Frequency" FontSize="12" Foreground="#555"/>
                    <ComboBox Name="FrequencyPicker" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Monthly" IsSelected="True"/>
                        <ComboBoxItem Content="Weekly"/>
                        <ComboBoxItem Content="Daily"/>
                        <ComboBoxItem Content="One-time"/>
                    </ComboBox>

                    <TextBlock Text="Category" FontSize="12" Foreground="#555"/>
                    <ComboBox Name="CategoryPicker" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Housing" IsSelected="True"/>
                        <ComboBoxItem Content="Food"/>
                        <ComboBoxItem Content="Transport"/>
                        <ComboBoxItem Content="Health"/>
                        <ComboBoxItem Content="Entertainment"/>
                        <ComboBoxItem Content="Subscriptions"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <TextBlock Name="ValidationMessage"
                               Foreground="Red"
                               FontSize="12"
                               IsVisible="False"/>

                    <Button Content="Add Expense"
                            Click="AddExpense_Click"
                            Background="#191970"
                            Foreground="White"
                            HorizontalAlignment="Right"
                            Padding="16,8"/>
                </StackPanel>
            </Border>

            <!-- Expense list -->
            <TextBlock Text="Current Expenses" FontWeight="SemiBold" FontSize="15"/>
            <StackPanel Name="ExpensesList" Spacing="6"/>

            <!-- Summary -->
            <Border Background="#f0f0fa" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Name="TotalLabel"  FontSize="13"/>
                    <TextBlock Name="RemainLabel" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
